# Core database
DATABASE_URL=postgresql://etholys:etholys_dev_change_me@localhost:5433/etholys

# Runtime
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ALLOW_ORIGINS=*
CORS_ALLOW_CREDENTIALS=false
DB_CONNECT_MAX_RETRIES=20
DB_CONNECT_RETRY_DELAY_SECONDS=1.5

# AI provider: gemini | ollama | openai
AI_PROVIDER=gemini

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Prompt
AI_SYSTEM_PROMPT=You are a helpful assistant for Etholys business and project data. Answer concisely in the same language as the user.

# API productization
API_ADMIN_TOKEN=change-me-admin-token
API_DEFAULT_RPM_LIMIT=60
API_REQUEST_LOG_RETENTION_DAYS=90
API_KEY_EXPIRY_WARNING_DAYS=14
API_USAGE_ALERT_THRESHOLDS=80,90,100
API_USAGE_WEBHOOK_TIMEOUT_SECONDS=3.0
API_USAGE_WEBHOOK_RETRY_BASE_MINUTES=1
API_USAGE_WEBHOOK_MAX_RETRIES=5
API_USAGE_WEBHOOK_AUTO_RETRY_PER_REQUEST=2
API_USAGE_WEBHOOK_SLO_THRESHOLD_MS=2000
