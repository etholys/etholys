# Banco local (Docker Compose): use o host postgres na rede interna
# DATABASE_URL="postgresql://etholys:etholys_dev_change_me@postgres:5432/etholys"
# No Windows/MAC, rodando npm run dev FORA do Docker com Postgres na porta 5433:
DATABASE_URL="postgresql://etholys:etholys_dev_change_me@localhost:5433/etholys"

# Obrigatório — sem isto login e muitas páginas falham. Use a mesma porta que o browser (ex.: 3001 se o Next avisar que 3000 está ocupada).
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="gere-um-segredo-longo-aleatorio"

# OAuth (opcional)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# S3 / notificações: manter do seu ambiente se precisar

# --- Google Gemini — todo o LLM na app (SIEP, MUSE, extratos, impostos, imagens) ---
# Chave: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash
# Predefinido no código: 65536; reduza só se a API reclamar
# GEMINI_MAX_OUTPUT_TOKENS=65536

# --- Backend FastAPI (contentor `api` no Docker usa o mesmo ficheiro .env) ---
# AI_PROVIDER=gemini

# --- PDF/HTML para relatórios (não é LLM; serviço Abacus ou outro) ---
# ABACUSAI_API_KEY=
# HTML2PDF_API_KEY=
