# Banco local (Docker Compose): use o host postgres na rede interna
# DATABASE_URL="postgresql://etholys:etholys_dev_change_me@postgres:5432/etholys"
# No Windows/MAC, rodando npm run dev FORA do Docker com Postgres na porta 5433:
DATABASE_URL="postgresql://etholys:etholys_dev_change_me@localhost:5433/etholys"

# Obrigatório — sem isto login e convites falham. Em produção use o domínio público (ex.: https://etholys.abacusai.app).
# Convites e links de alunos usam SEMPRE este valor.
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="gere-um-segredo-longo-aleatorio"

# Jitsi (FORGE Salón) — em produção use o vosso Meet self-hosted, não meet.jit.si (limite 5 min em iframe)
# JITSI_BASE_URL="https://meet.forge.etholys.com"

# OAuth (opcional)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Convites FORGE (opcional — sem isto o link mágico aparece na UI ao invitar)
# RESEND_API_KEY=
# FORGE_EMAIL_FROM="FORGE <convites@suaempresa.com>"
# Recordatorios automáticos (cron): POST /api/forge/cron/reminders con Bearer token
# FORGE_CRON_SECRET="gere-um-segredo-longo"
# E2E Playwright (só dev): POST /api/forge/e2e/seed com Bearer
# FORGE_E2E_SECRET="gere-um-segredo-longo"
# Cron diario sugerido:
# POST /api/forge/cron/reminders
# POST /api/forge/cron/auto-nudges

# S3 / notificações: manter do seu ambiente se precisar

# --- Google Gemini — todo o LLM na app (SIEP, MUSE, extratos, impostos, imagens) ---
# Chave: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash
# Predefinido no código: 65536; reduza só se a API reclamar
# GEMINI_MAX_OUTPUT_TOKENS=65536

# --- Backend FastAPI (contentor `api` no Docker usa o mesmo ficheiro .env) ---
# AI_PROVIDER=gemini

# --- PDF/HTML para relatórios (não é LLM; serviço Abacus ou outro) ---
# ABACUSAI_API_KEY=
# HTML2PDF_API_KEY=
