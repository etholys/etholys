generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

model ProductionOrder {
  id         String                     @id @default(cuid())
  companyId  String
  productId  String
  quantity   Float
  status     String                     @default("pending")
  createdAt  DateTime                   @default(now())
  updatedAt  DateTime                   @updatedAt
  company    Company                    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  product    Product                    @relation(fields: [productId], references: [id], onDelete: Cascade)
  components ProductionOrderComponent[]

  @@index([companyId])
  @@index([productId])
}

model ProductionOrderComponent {
  id                String          @id @default(cuid())
  productionOrderId String
  componentId       String
  quantity          Float
  unit              String?
  component         Product         @relation("ProductionOrderComponent_componentIdToProduct", fields: [componentId], references: [id], onDelete: Cascade)
  productionOrder   ProductionOrder @relation(fields: [productionOrderId], references: [id], onDelete: Cascade)

  @@index([productionOrderId])
  @@index([componentId])
}

model User {
  id                            String                       @id @default(cuid())
  name                          String
  email                         String                       @unique
  password                      String                       @default("")
  emailVerified                 DateTime?
  image                         String?
  role                          UserRole                     @default(COLLABORATOR)
  avatar                        String?
  phone                         String?
  locale                        String                       @default("es")
  isActive                      Boolean                      @default(true)
  createdAt                     DateTime                     @default(now())
  updatedAt                     DateTime                     @updatedAt
  accounts                      Account[]
  activities                    Activity[]
  aiSessions                    AiAdvisorSession[]
  aiAlerts                      AiAlert[]
  workChatSessions              WorkChatSession[]
  chatChannelMembers            ChatChannelMember[]
  chatMessages                  ChatMessage[]
  comments                      Comment[]
  companyUsers                  CompanyUser[]
  departmentUsers               DepartmentUser[]
  employeeContracts             EmployeeContract[]
  initiatedFundhubDiscoveryRuns FundhubDiscoveryRun[]
  fundingOpportunityFeedbacks   FundingOpportunityFeedback[]
  invitations                   Invitation[]
  labInvitesSent                LabInvite[]                  @relation("LabInviteSender")
  labInvitesReceived            LabInvite[]                  @relation("LabInviteUser")
  museSuggestions               MuseSuggestion[]
  notifications                 Notification[]
  projectMembers                ProjectMember[]
  createdProposals              Proposal[]                   @relation("ProposalCreator")
  proposalComments              ProposalComment[]            @relation("ProposalCommentCreator")
  uploadedProposalFiles         ProposalFile[]               @relation("ProposalFileUploader")
  proposalVersions              ProposalVersion[]            @relation("ProposalVersionCreator")
  sessions                      Session[]
  assignedTasks                 Task[]                       @relation("TaskAssignee")
  createdTasks                  Task[]                       @relation("TaskCreator")
  taskTemplates                 TaskTemplate[]               @relation("TemplateCreator")
  taxFilings                    TaxFiling[]
  timeEntries                   TimeEntry[]
  userMonitoredSources          UserMonitoredSource[]
  fundhubAlerts                 FundhubAlert[]
  fundhubEligibilityChecks      FundhubEligibilityCheck[]
  integratedWorkspaceGrants     IntegratedWorkspaceAccess[] @relation("WorkspaceGrantee")
  integratedWorkspaceGrantsCreated IntegratedWorkspaceAccess[] @relation("WorkspaceGrantedBy")
  forgeEnrollments              ForgeEnrollment[]
  forgeActivityProgress         ForgeActivityProgress[]
  forgeLearnerProfiles          ForgeLearnerProfile[]
  forgeLearnerJourneys          ForgeLearnerJourney[]
  forgeGameSessions             ForgeGameSession[]
  forgeSharedGameRoomsFacilitated ForgeSharedGameRoom[] @relation("ForgeSharedGameFacilitator")
  forgeGamificationEvents       ForgeGamificationEvent[]
  forgeCertificates             ForgeCertificate[]
  forgeCoursesCreated           ForgeCourse[]              @relation("ForgeCourseCreator")
  forgeCourseFacilitators       ForgeCourseFacilitator[]
  forgeFeriaRegistrations       ForgeFeriaRegistration[]
  forgeLiveAttendances          ForgeLiveAttendance[]
  activityReportsAuthored       TaskActivityReport[]         @relation("ActivityReportAuthor")
  activityReportsReviewed       TaskActivityReport[]         @relation("ActivityReportReviewer")
  reportGuidesUploaded          ProjectReportGuide[]         @relation("ReportGuideUploader")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Company {
  id                          String                       @id @default(cuid())
  name                        String
  shortName                   String
  description                 String?
  logo                        String?
  color                       String                       @default("#0D9488")
  currency                    String                       @default("USD")
  isActive                    Boolean                      @default(true)
  createdAt                   DateTime                     @default(now())
  updatedAt                   DateTime                     @updatedAt
  ein                         String?
  incorporationDate           DateTime?
  incorporationCountry        String?
  taxAddress                  String?
  businessActivityCode        String?
  businessActivity            String?
  entityType                  String?
  /// Respostas do assistente de contexto (sector, comércio, metas) — aciona módulos e memória de IA; não substitui aconselhamento legal.
  contextSetupJson            Json?
  contextSetupAt              DateTime?
  aiSessions                  AiAdvisorSession[]
  aiAlerts                    AiAlert[]
  aiMemories                  AiCompanyMemory[]
  chatChannels                ChatChannel[]
  workChatSessions            WorkChatSession[]
  clients                     Client[]
  companyBudgetItems          CompanyBudgetItem[]
  companyBudgetLines          CompanyBudgetLine[]
  companyUsers                CompanyUser[]
  customRoles                 CustomRole[]
  departments                 Department[]
  documents                   Document[]
  employeeContracts           EmployeeContract[]
  funds                       Fund[]
  fundhubComplianceChecklists FundhubComplianceChecklist[]
  fundhubDiscoveryRuns        FundhubDiscoveryRun[]
  fundhubAlerts               FundhubAlert[]
  fundhubEligibilityChecks    FundhubEligibilityCheck[]
  fundhubPartners             FundhubPartner[]
  fundingCaptureProfile       FundingCaptureProfile?
  fundingOpportunityFeedbacks FundingOpportunityFeedback[]
  invitations                 Invitation[]
  invoices                    Invoice[]
  leaveRequests               LeaveRequest[]
  museSuggestions             MuseSuggestion[]
  nexusNetworksAnchored       NexusNetwork[]               @relation("NexusNetworkAnchor")
  nexusNetworkMemberships     NexusNetworkMember[]
  nexusVentureState           NexusVentureState?
  /// Quem pode usar o Centro de trabalho integrado nesta empresa (não duplica lógica dos sistemas; só espelha APIs).
  integratedWorkspaceAccesses  IntegratedWorkspaceAccess[]
  products                    Product[]
  productComponents           ProductComponent[]           @relation("CompanyProductComponents")
  productPricingVersions      ProductPricingVersion[]
  productionOrders            ProductionOrder[]
  projects                    Project[]
  proposals                   Proposal[]
  purchaseOrders              PurchaseOrder[]
  stakeholders                Stakeholder[]
  suppliers                   Supplier[]
  taskTemplates               TaskTemplate[]
  taxFilings                  TaxFiling[]
  transactions                Transaction[]
  transactionCategories       TransactionCategory[]
  userMonitoredSources        UserMonitoredSource[]
  forgePrograms               ForgeProgram[]
  forgeCourses                ForgeCourse[]
  forgeGameSpecs              ForgeGameSpec[]
  forgeGamificationEvents     ForgeGamificationEvent[]
  forgeCertificates           ForgeCertificate[]
}

/// Autorização ao Hub /hub/workspace — espelho operacional: quais sistemas o utilizador vê e usa a partir dali (dados continuam nos sistemas de origem).
model IntegratedWorkspaceAccess {
  id              String   @id @default(cuid())
  companyId       String
  userId          String
  /// JSON: ["ATLAS","SIEP","FUNDHUB","NEXUS","FORGE","PRISM"] — subconjunto contratado / relevante
  systems         Json     @default("[]")
  enabled         Boolean  @default(true)
  grantedByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user            User     @relation("WorkspaceGrantee", fields: [userId], references: [id], onDelete: Cascade)
  grantedBy       User?    @relation("WorkspaceGrantedBy", fields: [grantedByUserId], references: [id], onDelete: SetNull)

  @@unique([companyId, userId])
  @@index([companyId])
  @@index([userId])
}

model Department {
  id        String           @id @default(cuid())
  companyId String
  name      String
  code      String?
  headId    String?
  isActive  Boolean          @default(true)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  company   Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  users     DepartmentUser[]
  tasks     Task[]
}

model CompanyUser {
  id              String   @id @default(cuid())
  userId          String
  companyId       String
  role            UserRole @default(COLLABORATOR)
  isDefault       Boolean  @default(false)
  /// Permissões SIEP granulares (array JSON de chaves — ver lib/siep/permissions.ts)
  siepPermissions Json?
  createdAt       DateTime @default(now())
  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
}

model DepartmentUser {
  id           String     @id @default(cuid())
  userId       String
  departmentId String
  role         String     @default("member")
  createdAt    DateTime   @default(now())
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, departmentId])
}

model CustomRole {
  id          String   @id @default(cuid())
  companyId   String?
  name        String   @unique
  description String   @default("")
  code        String   @default("")
  level       Int      @default(0)
  permissions String?
  color       String   @default("#6b7280")
  isSystem    Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company     Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Objective {
  id              String                 @id @default(cuid())
  projectId       String
  parentId        String?
  type            String                 @default("objective")
  code            String?
  title           String
  description     String?
  indicator       String?
  indicatorType   String?
  unitOfMeasure   String?
  dataSource      String?
  disaggregation  String?
  reportingFreq   String?
  responsibility  String?
  dataLimitations String?
  baseline        String?
  target          String?
  actual          String?
  status          String                 @default("not_started")
  order           Int                    @default(0)
  isActive        Boolean                @default(true)
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  measurements    IndicatorMeasurement[]
  parent          Objective?             @relation("ObjectiveTree", fields: [parentId], references: [id])
  children        Objective[]            @relation("ObjectiveTree")
  project         Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Project {
  id                         String                 @id @default(cuid())
  name                       String
  code                       String?
  description                String?
  goal                       String?
  companyId                  String
  donorName                  String?
  donorContact               String?
  status                     ProjectStatus          @default(DRAFT)
  priority                   Priority               @default(MEDIUM)
  startDate                  DateTime?
  endDate                    DateTime?
  budget                     Float                  @default(0)
  spent                      Float                  @default(0)
  progress                   Int                    @default(0)
  country                    String?
  region                     String?
  currency                   String                 @default("USD")
  contentLocale              String?                @default("es")
  color                      String                 @default("#60B5FF")
  isActive                   Boolean                @default(true)
  createdAt                  DateTime               @default(now())
  updatedAt                  DateTime               @updatedAt
  activities                 Activity[]
  budgetItemFundings         BudgetItemFunding[]
  budgetLines                BudgetLine[]
  companyBudgetItems         CompanyBudgetItem[]
  indicatorMeasurements      IndicatorMeasurement[]
  meReports                  MEReport[]
  meReportPackages           MEReportPackage[]
  meReportFiles              MEReportFile[]
  milestones                 Milestone[]
  museSuggestions            MuseSuggestion[]
  nexusNetworksAsContext     NexusNetwork[]         @relation("NexusNetworkSiepProject")
  nexusNetworkMemberProjects NexusNetworkMember[]   @relation("NexusMemberSiepProject")
  objectives                 Objective[]
  company                    Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  members                    ProjectMember[]
  risks                      Risk[]
  sowSections                SOWSection[]
  tasks                      Task[]
  transactions               Transaction[]
  activityReports            TaskActivityReport[]
  reportGuides               ProjectReportGuide[]
}

/// Manual / guía de reporte del financiador — referencia permanente para la IA.
model ProjectReportGuide {
  id               String   @id @default(cuid())
  projectId        String
  title            String
  fileName         String
  cloudStoragePath String
  mimeType         String?
  fileSizeBytes    Int      @default(0)
  extractedText    String?  @db.Text
  extractionStatus String   @default("pending")
  /// general | me | budget — ámbito del manual para la IA
  domain           String   @default("general")
  uploadedById     String?
  order            Int      @default(0)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploadedBy       User?    @relation("ReportGuideUploader", fields: [uploadedById], references: [id])

  @@index([projectId])
}

model ProjectMember {
  id            String   @id @default(cuid())
  projectId     String
  userId        String
  role          String   @default("member")
  createdAt     DateTime @default(now())
  dedicationPct Float    @default(100)
  monthlyCost   Float?
  updatedAt     DateTime @default(now()) @updatedAt
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}

model Task {
  id               String           @id @default(cuid())
  title            String
  description      String?
  projectId        String?
  companyId        String?
  assigneeId       String?
  creatorId        String
  parentId         String?
  status           TaskStatus       @default(TODO)
  priority         Priority         @default(MEDIUM)
  startDate        DateTime?
  dueDate          DateTime?
  completedAt      DateTime?
  estimatedHours   Float?
  order            Int              @default(0)
  tags             String?
  isActive         Boolean          @default(true)
  isRecurring      Boolean          @default(false)
  recurrenceMonths Int?
  recurrenceGroup  String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  departmentId     String?
  attachments      Attachment[]
  checklist        ChecklistItem[]
  comments         Comment[]
  assignee         User?            @relation("TaskAssignee", fields: [assigneeId], references: [id])
  creator          User             @relation("TaskCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  department       Department?      @relation(fields: [departmentId], references: [id])
  parent           Task?            @relation("SubTasks", fields: [parentId], references: [id])
  subtasks         Task[]           @relation("SubTasks")
  project          Project?         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  dependedBy       TaskDependency[] @relation("DependencyTask")
  dependsOn        TaskDependency[] @relation("DependentTask")
  timeEntries      TimeEntry[]
  activityReports  TaskActivityReport[]
}

model TaskDependency {
  id              String   @id @default(cuid())
  taskId          String
  dependsOnTaskId String
  type            String   @default("finish_to_start")
  lagDays         Int      @default(0)
  createdAt       DateTime @default(now())
  dependsOn       Task     @relation("DependencyTask", fields: [dependsOnTaskId], references: [id], onDelete: Cascade)
  task            Task     @relation("DependentTask", fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([taskId, dependsOnTaskId])
}

model TaskTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?
  companyId   String?
  category    String?
  tasks       Json
  createdBy   String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company     Company? @relation(fields: [companyId], references: [id])
  creator     User     @relation("TemplateCreator", fields: [createdBy], references: [id], onDelete: Cascade)
}

model ChecklistItem {
  id        String   @id @default(cuid())
  taskId    String
  text      String
  completed Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model Comment {
  id        String   @id @default(cuid())
  taskId    String
  userId    String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Attachment {
  id               String   @id @default(cuid())
  taskId           String
  fileName         String
  fileSize         Int
  fileType         String
  cloudStoragePath String
  isPublic         Boolean  @default(false)
  createdAt        DateTime @default(now())
  task             Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model TimeEntry {
  id          String   @id @default(cuid())
  taskId      String
  userId      String
  hours       Float
  description String?
  date        DateTime
  createdAt   DateTime @default(now())
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Milestone {
  id          String    @id @default(cuid())
  projectId   String
  name        String
  description String?
  dueDate     DateTime?
  completed   Boolean   @default(false)
  completedAt DateTime?
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Risk {
  id          String    @id @default(cuid())
  projectId   String
  title       String
  description String?
  level       RiskLevel @default(MEDIUM)
  impact      String?
  mitigation  String?
  status      String    @default("open")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Transaction {
  id                  String             @id @default(cuid())
  companyId           String
  projectId           String?
  type                TransactionType
  amount              Float
  currency            String             @default("USD")
  title               String?
  description         String?
  category            String?
  date                DateTime           @default(now())
  accrualDate         DateTime?
  isRecurring         Boolean            @default(false)
  recurrenceMonths    Int?
  executionStatus     String             @default("FORECAST")
  executedDate        DateTime?
  createdAt           DateTime           @default(now())
  budgetLineId        String?
  scope               String             @default("SHARED")
  companyAmount       Float?
  note                String?
  origin              String?
  companyBudgetItemId String?
  receiptUrl          String?
  budgetLine          BudgetLine?        @relation(fields: [budgetLineId], references: [id])
  companyBudgetItem   CompanyBudgetItem? @relation(fields: [companyBudgetItemId], references: [id])
  company             Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  project             Project?           @relation(fields: [projectId], references: [id])
  activityReport      TaskActivityReport?

  @@index([budgetLineId])
  @@index([companyBudgetItemId])
  @@index([scope])
}

model TransactionCategory {
  id        String   @id @default(cuid())
  companyId String
  name      String
  color     String   @default("#6B7280")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, name])
}

model CompanyBudgetLine {
  id            String                     @id @default(cuid())
  companyId     String
  name          String
  nameEs        String?
  namePt        String?
  icon          String?
  color         String                     @default("#6B7280")
  order         Int                        @default(0)
  isSystem      Boolean                    @default(false)
  isActive      Boolean                    @default(true)
  createdAt     DateTime                   @default(now())
  updatedAt     DateTime                   @updatedAt
  items         CompanyBudgetItem[]
  company       Company                    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  subcategories CompanyBudgetSubcategory[]

  @@unique([companyId, name])
  @@index([companyId])
}

model CompanyBudgetSubcategory {
  id           String              @id @default(cuid())
  budgetLineId String
  name         String
  nameEs       String?
  namePt       String?
  isSystem     Boolean             @default(false)
  isActive     Boolean             @default(true)
  createdAt    DateTime            @default(now())
  items        CompanyBudgetItem[]
  budgetLine   CompanyBudgetLine   @relation(fields: [budgetLineId], references: [id], onDelete: Cascade)

  @@unique([budgetLineId, name])
  @@index([budgetLineId])
}

model CompanyBudgetItem {
  id            String                    @id @default(cuid())
  companyId     String
  budgetLineId  String
  subcategoryId String?
  description   String
  unit          String                    @default("month")
  quantity      Float                     @default(1)
  unitCost      Float                     @default(0)
  total         Float                     @default(0)
  currency      String                    @default("USD")
  periodStart   DateTime?
  periodEnd     DateTime?
  note          String?
  origin        String?
  projectId     String?
  allocationPct Float                     @default(100)
  order         Int                       @default(0)
  isActive      Boolean                   @default(true)
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt
  budgetFlow    String                    @default("EXPENSE")
  fundingSplits BudgetItemFunding[]
  budgetLine    CompanyBudgetLine         @relation(fields: [budgetLineId], references: [id], onDelete: Cascade)
  company       Company                   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  project       Project?                  @relation(fields: [projectId], references: [id])
  subcategory   CompanyBudgetSubcategory? @relation(fields: [subcategoryId], references: [id])
  transactions  Transaction[]

  @@index([companyId, isActive])
  @@index([budgetLineId, order])
  @@index([subcategoryId])
  @@index([projectId])
}

model BudgetItemFunding {
  id           String            @id @default(cuid())
  budgetItemId String
  projectId    String?
  percentage   Float             @default(100)
  periodStart  DateTime?
  periodEnd    DateTime?
  note         String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  budgetItem   CompanyBudgetItem @relation(fields: [budgetItemId], references: [id], onDelete: Cascade)
  project      Project?          @relation(fields: [projectId], references: [id])

  @@index([budgetItemId])
  @@index([projectId])
}

model Activity {
  id        String   @id @default(cuid())
  userId    String
  projectId String?
  action    String
  details   String?
  createdAt DateTime @default(now())
  project   Project? @relation(fields: [projectId], references: [id])
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Invoice {
  id               String        @id @default(cuid())
  companyId        String
  supplierId       String?
  projectId        String?
  type             InvoiceType
  status           InvoiceStatus @default(DRAFT)
  number           String
  description      String?
  contactName      String?
  contactEmail     String?
  currency         String        @default("USD")
  subtotal         Float         @default(0)
  taxRate          Float         @default(0)
  taxAmount        Float         @default(0)
  total            Float         @default(0)
  issueDate        DateTime      @default(now())
  dueDate          DateTime?
  paidDate         DateTime?
  notes            String?
  isActive         Boolean       @default(true)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  relatedInvoiceId String?
  company          Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  relatedInvoice   Invoice?      @relation("InvoiceNotes", fields: [relatedInvoiceId], references: [id])
  creditDebitNotes Invoice[]     @relation("InvoiceNotes")
  supplier         Supplier?     @relation(fields: [supplierId], references: [id])
  items            InvoiceItem[]
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String
  description String
  quantity    Float   @default(1)
  unitPrice   Float   @default(0)
  total       Float   @default(0)
  order       Int     @default(0)
