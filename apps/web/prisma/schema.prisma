/// Checklist de compliance por empresa — persiste o estado (JSON) de cada categoria
model FundhubComplianceChecklist {
  id          String   @id @default(cuid())
  companyId   String
  fundId      String?  // null = checklist genérico, preenchido = associado a um fundo
  checklistId String   // ex: "governance", "financial", "esg", "compliance"
  itemsJson   String   // JSON: { [itemId]: boolean }
  notes       String?
  updatedAt   DateTime @updatedAt
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, fundId, checklistId])
  @@index([companyId])
}

