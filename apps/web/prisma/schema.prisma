model LabInvite {
  id          String   @id @default(cuid())
  email       String
  code        String   @unique
  status      String   @default("PENDING")
  invitedById String
  userId      String?
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  invitedBy   User     @relation("LabInviteSender", fields: [invitedById], references: [id], onDelete: Cascade)
  user        User?    @relation("LabInviteUser", fields: [userId], references: [id])

  @@index([email])
  @@index([code])
}

model SOWSection {
  id         String   @id @default(cuid())
  projectId  String
  sectionKey String
  title      String
  content    String   @default("")
  order      Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, sectionKey])
  @@index([projectId])
}

model BudgetLine {
  id           String        @id @default(cuid())
  projectId    String
  category     String
  description  String
  unit         String?
  /// fixed | percent_of_direct
  unitType     String         @default("fixed")
  quantity     Float         @default(1)
  unitCost     Float         @default(0)
  total        Float         @default(0)
  narrative    String        @default("")
  fundSource   String        @default("federal")
  periodStart  DateTime?
  periodEnd    DateTime?
  order        Int           @default(0)
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  project         Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  transactions    Transaction[]
  activityReports TaskActivityReport[]

  @@index([projectId])
  @@index([projectId, category])
}

/// Informe interno de avance por actividade (alimenta M&E / reportes externos).
model TaskActivityReport {
  id              String            @id @default(cuid())
  projectId       String
  taskId          String
  authorId        String
  reportDate      DateTime          @default(now())
  narrative       String            @default("")
  progressPct     Int?
  status          String            @default("draft")
  budgetLineId    String?
  photoUrls       Json              @default("[]")
  deliverableUrls Json              @default("[]")
  includesTravel  Boolean           @default(false)
  reviewedById    String?
  reviewedAt      DateTime?
  reviewNotes     String?
  transactionId   String?           @unique
  isActive        Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  project         Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task            Task              @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author          User              @relation("ActivityReportAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  reviewer        User?             @relation("ActivityReportReviewer", fields: [reviewedById], references: [id])
  budgetLine      BudgetLine?       @relation(fields: [budgetLineId], references: [id])
  mileage         TaskMileageClaim?
  transaction     Transaction?      @relation(fields: [transactionId], references: [id])

  @@index([projectId, taskId])
  @@index([authorId])
  @@index([status])
}

/// Reembolso de combustível / visita de campo ligado a um informe.
model TaskMileageClaim {
  id                   String             @id @default(cuid())
  reportId             String             @unique
  odometerStart        Float
  odometerEnd          Float
  distanceKm           Float
  fromPlace            String
  toPlace              String
  city                 String
  country              String
  odometerStartPhoto   String?
  odometerEndPhoto     String?
  receiptUrls          Json               @default("[]")
  fuelPriceUsdPerLiter Float?
  fuelLitersEstimated  Float?
  reimbursementUsd     Float?
  status               String             @default("pending")
  aiEstimateNotes      String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  report               TaskActivityReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
}

model IndicatorMeasurement {
  id          String    @id @default(cuid())
  projectId   String
  objectiveId String
  period      String
  value       String
  notes       String?
  source      String?
  collectedAt DateTime  @default(now())
  collectedBy String?
  status      String    @default("reported")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  objective   Objective @relation(fields: [objectiveId], references: [id], onDelete: Cascade)
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([objectiveId])
  @@index([projectId, period])
}

model MEReport {
  id              String            @id @default(cuid())
  projectId       String
  title           String
  type            String            @default("progress")
  period          String?
  content         String            @default("")
  findings        String?
  recommendations String?
  status          String            @default("draft")
  reportDate      DateTime          @default(now())
  /// monthly | quarterly | annual | adhoc
  cadence         String?
  /// narrative | me_indicators | financial | evidence_links | other
  component       String?
  /// usaid | bid | eu | generic
  donorFormat     String?
  packageId       String?
  parentReportId  String?
  /// Editor canvas (regions/cells mapped to template)
  canvasState     Json?
  canvasFormat    String?
  aiSessionId     String?
  periodStart     DateTime?
  periodEnd       DateTime?
  isActive        Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  project         Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  package         MEReportPackage?  @relation(fields: [packageId], references: [id], onDelete: SetNull)
  parentReport    MEReport?         @relation("MEReportRollup", fields: [parentReportId], references: [id], onDelete: SetNull)
  childReports    MEReport[]        @relation("MEReportRollup")

  @@index([projectId])
  @@index([projectId, type])
  @@index([packageId])
  @@index([parentReportId])
}

model MEReportPackage {
  id              String         @id @default(cuid())
  projectId       String
  title           String
  /// monthly | quarterly | annual
  cadence         String         @default("quarterly")
  period          String?
  periodStart     DateTime?
  periodEnd       DateTime?
  status          String         @default("draft")
  donorFormat     String         @default("generic")
  /// me | budget — separa pacotes M&E de informes financieros
  domain          String         @default("me")
  notes           String?
  /// Pacote trimestral alimentado por pacotes mensais
  parentPackageId String?
  isActive        Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  project         Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parentPackage   MEReportPackage? @relation("MEReportPackageRollup", fields: [parentPackageId], references: [id], onDelete: SetNull)
  childPackages   MEReportPackage[] @relation("MEReportPackageRollup")
  files           MEReportFile[]
  reports         MEReport[]

  @@index([projectId])
  @@index([projectId, cadence])
  @@index([parentPackageId])
}

model MEReportFile {
  id                  String          @id @default(cuid())
  packageId           String
  projectId           String
  fileName            String
  cloudStoragePath    String
  mimeType            String?
  fileSizeBytes       Int             @default(0)
  /// narrative | me_indicators | financial | evidence_links | other
  component           String          @default("other")
  cadence             String?
  aiDetectedComponent String?
  aiDetectedCadence   String?
  aiValidation        Json?
  userConfirmed       Boolean         @default(false)
  order               Int             @default(0)
  isActive            Boolean         @default(true)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  package             MEReportPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  project             Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([packageId])
  @@index([projectId])
}

model TaxFiling {
  id          String    @id @default(cuid())
  companyId   String
  formType    String
  taxYear     Int
  status      String    @default("draft")
  formData    Json      @default("{}")
  autoData    Json      @default("{}")
  notes       String?
  filedDate   DateTime?
  isActive    Boolean   @default(true)
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy   User?     @relation(fields: [createdById], references: [id])

  @@unique([companyId, formType, taxYear])
  @@index([companyId])
}

enum AiAdvisorSessionKind {
  WORKSPACE_ADVISOR
  NEXUS_COPILOT
  SIEP_REPORT
}

model AiAdvisorSession {
  id        String                 @id @default(cuid())
  companyId String
  userId    String
  title     String?
  /** Separa o assessor “workspace” (/hub/advisor + chat IA contexto) do copiloto NEXUS (/hub/nexus); evita misturar prompts na mesma sessão. */
  kind      AiAdvisorSessionKind @default(WORKSPACE_ADVISOR)
  /// Estado espelhado na coluna direita do NEXUS (acordo com assessor IA + artefactos; conversa como fonte de verdade)
  nexusMirror Json?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  messages  AiAdvisorMessage[]
  company   Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([userId])
}

model AiAdvisorMessage {
  id        String           @id @default(cuid())
  sessionId String
  role      String
  content   String
  context   Json?
  createdAt DateTime         @default(now())
  session   AiAdvisorSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model AiCompanyMemory {
  id        String    @id @default(cuid())
  companyId String
  category  String
  key       String
  value     String
  source    String?
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([companyId, category])
}

model AiAlert {
  id          String    @id @default(cuid())
  companyId   String
  userId      String?
  type        String
  severity    String    @default("info")
  title       String
  message     String
  link        String?
  read        Boolean   @default(false)
  dismissedAt DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user        User?     @relation(fields: [userId], references: [id])

  @@index([companyId])
  @@index([userId])
  @@index([companyId, read])
}

model WorkChatSession {
  id        String            @id @default(cuid())
  channelId String
  companyId String
  userId    String
  title     String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  channel   ChatChannel       @relation(fields: [channelId], references: [id], onDelete: Cascade)
  messages  WorkChatMessage[]
  company   Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
  @@index([companyId])
  @@index([userId])
  @@index([channelId])
}

model WorkChatMessage {
  id        String           @id @default(cuid())
  sessionId String
  role      String
  content   String
  context   Json?
  createdAt DateTime         @default(now())
  session   WorkChatSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

// --- FORGE (EAD unificado: cursos + atividades + jogos + gamificação) ---

model ForgeProgram {
  id           String        @id @default(cuid())
  companyId    String
  title        String
  description  String?
  isActive     Boolean       @default(true)
  /** Si true, los cursos deben completarse en programSortOrder */
  enforceOrder Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  courses      ForgeCourse[]

  @@index([companyId])
}

model ForgeCourse {
  id             String                  @id @default(cuid())
  companyId      String
  programId      String?
  createdById    String?
  title          String
  description    String?
  status         String                  @default("draft")
  /** async | live | blended — assíncrono, só vide chamada, ou ambos */
  deliveryMode   String                  @default("async")
  /** personal = cada aluno seu tabuleiro; shared_live = tablero único do facilitador */
  gamePlayMode   String                  @default("personal")
  /** open = aparece no catálogo da org; invite_only = só alunos convidados ao curso */
  cohortMode     String                  @default("invite_only")
  /** { meetingUrl, platform, scheduledLabel, facilitatorNotes, roomName } */
  liveConfig     Json?
  coverEmoji     String                  @default("📚")
  gamification   Json?
  estimatedHours Int?
  programSortOrder Int                   @default(0)
  /** PDF del libro didáctico (S3 o /public/uploads/forge) */
  libroPdfPath     String?
  libroPdfName     String?
  /** Texto extraído del PDF (pdf-parse + Gemini OCR si hace falta) */
  libroOcrText     String?                 @db.Text
  libroOcrStatus   String?                 /// pending | done | failed | skipped
  libroOcrAt       DateTime?
  libroOcrMeta     Json?                   /// { method, pages, charCount }
  /** PDF exportado de la PPT o archivo de diapositivas */
  presentationPdfPath   String?
  presentationPdfName   String?
  presentationEmbedUrl  String?
  /** Diapositivas integradas (guion PPT) — { n, title, visual, texto, guion, tecnico, accion }[] */
  presentationSlides    Json?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  company        Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  program        ForgeProgram?           @relation(fields: [programId], references: [id], onDelete: SetNull)
  createdBy      User?                   @relation("ForgeCourseCreator", fields: [createdById], references: [id], onDelete: SetNull)
  modules        ForgeModule[]
  facilitators   ForgeCourseFacilitator[]
  enrollments    ForgeEnrollment[]
  learnerProfiles ForgeLearnerProfile[]
  learnerJourneys ForgeLearnerJourney[]
  certificates    ForgeCertificate[]
  liveSessions   ForgeLiveSession[]
  sharedGameRooms ForgeSharedGameRoom[]
  playGroups     ForgePlayGroup[]
  editions       ForgeCourseEdition[]
  feriaSessions  ForgeFeriaSession[]

  @@index([companyId, status])
  @@index([programId])
}

/// Edição / turma — uma execução do curso (várias empresas/grupos dentro)
model ForgeCourseEdition {
  id        String   @id @default(cuid())
  courseId  String
  name      String
  /** preparation | running | finished | archived */
  status    String   @default("preparation")
  startsAt  DateTime?
  endsAt    DateTime?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  course    ForgeCourse    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  playGroups ForgePlayGroup[]

  @@index([courseId, status])
  @@index([courseId, startsAt])
}

/// Sessão de feira / capacitação presencial — código curto da sala + agrupamento automático
model ForgeFeriaSession {
  id        String   @id @default(cuid())
  courseId  String
  roomCode  String
  title     String?
  teamSize  Int      @default(4)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  course    ForgeCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)
  playGroups ForgePlayGroup[]
  registrations ForgeFeriaRegistration[]

  @@unique([courseId, roomCode])
  @@index([roomCode])
  @@index([courseId, active])
}

/// Inscrição na feira — um código pessoal por email por sessão
model ForgeFeriaRegistration {
  id          String   @id @default(cuid())
  sessionId   String
  userId      String
  email       String
  accessCode  String
  name        String
  ageRange    String?
  gender      String?
  locale      String   @default("es")
  playGroupId String
  registeredAt DateTime @default(now())
  session     ForgeFeriaSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  playGroup   ForgePlayGroup @relation(fields: [playGroupId], references: [id], onDelete: Cascade)

  @@unique([sessionId, email])
  @@unique([sessionId, accessCode])
  @@index([playGroupId])
  @@index([userId])
}

/// Turma / empresa / instancia de coaching (varios jogadores, um link de convite)
model ForgePlayGroup {
  id              String                @id @default(cuid())
  courseId        String
  editionId       String?
  liveSessionId   String?
  feriaSessionId  String?
  name            String
  /** live_team = jogo colectivo; individual_coaching = pos-jogo 1:1 */
  mode            String                @default("live_team")
  /** Grupo criado automaticamente na feira (agrupamento aleatório) */
  autoGenerated   Boolean               @default(false)
  inviteToken     String?               @unique
  inviteExpiresAt DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  course          ForgeCourse           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  edition         ForgeCourseEdition?   @relation(fields: [editionId], references: [id], onDelete: SetNull)
  liveSession     ForgeLiveSession?     @relation(fields: [liveSessionId], references: [id], onDelete: SetNull)
  feriaSession    ForgeFeriaSession?    @relation(fields: [feriaSessionId], references: [id], onDelete: SetNull)
  enrollments     ForgeEnrollment[]
  sharedGameRooms ForgeSharedGameRoom[]
  feriaRegistrations ForgeFeriaRegistration[]

  @@index([courseId])
  @@index([editionId])
  @@index([liveSessionId])
  @@index([feriaSessionId])
}

/// Sessão agendada ao vivo (calendário do curso)
model ForgeLiveSession {
  id                 String                 @id @default(cuid())
  courseId           String
  title              String
  startsAt           DateTime
  endsAt             DateTime?
  meetingUrl         String?
  /** Grabación publicada (YouTube, Drive, etc.) tras la sesión */
  recordingUrl       String?
  recordingNotes     String?
  activityId         String?
  facilitatorNotes   String?
  sortOrder          Int                    @default(0)
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  course             ForgeCourse            @relation(fields: [courseId], references: [id], onDelete: Cascade)
  focusActivity      ForgeLearningActivity? @relation(fields: [activityId], references: [id], onDelete: SetNull)
  sharedGameRooms    ForgeSharedGameRoom[]
  attendances        ForgeLiveAttendance[]
  playGroups         ForgePlayGroup[]

  @@index([courseId, startsAt])
  @@index([activityId])
}

model ForgeLiveAttendance {
  id            String           @id @default(cuid())
  liveSessionId String
  userId        String
  joinedAt      DateTime         @default(now())
  leftAt        DateTime?
  liveSession   ForgeLiveSession @relation(fields: [liveSessionId], references: [id], onDelete: Cascade)
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([liveSessionId, userId])
  @@index([userId])
}

model ForgeCourseFacilitator {
  id        String      @id @default(cuid())
  courseId  String
  userId    String
  role      String      @default("facilitator")
  course    ForgeCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([courseId, userId])
  @@index([userId])
}

model ForgeModule {
  id        String                 @id @default(cuid())
  courseId  String
  title     String
  sortOrder Int                    @default(0)
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt
  course    ForgeCourse            @relation(fields: [courseId], references: [id], onDelete: Cascade)
  activities ForgeLearningActivity[]

  @@index([courseId, sortOrder])
}

/// Atividade de aprendizagem FORGE (não confundir com model Activity = audit log)
model ForgeLearningActivity {
  id         String                @id @default(cuid())
  moduleId   String
  type       String
  title      String
  sortOrder  Int                   @default(0)
  config     Json                  @default("{}")
  gameSpecId String?
  xpWeight   Float                 @default(1)
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt
  module     ForgeModule           @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  gameSpec   ForgeGameSpec?        @relation(fields: [gameSpecId], references: [id], onDelete: SetNull)
  progress   ForgeActivityProgress[]
  gameSessions ForgeGameSession[]
  liveSessions ForgeLiveSession[]
  sharedGameRooms ForgeSharedGameRoom[]

  @@index([moduleId, sortOrder])
  @@index([gameSpecId])
}

/// Tablero/juego compartido en sesión en vivo (estado único para toda la clase)
model ForgeSharedGameRoom {
  id                String                 @id @default(cuid())
  activityId        String
  courseId          String
  liveSessionId     String?
  playGroupId       String?
  facilitatorUserId String
  state             Json                   @default("{}")
  lastEvents        Json?
  status            String                 @default("open")
  version           Int                    @default(0)
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  activity          ForgeLearningActivity  @relation(fields: [activityId], references: [id], onDelete: Cascade)
  course            ForgeCourse            @relation(fields: [courseId], references: [id], onDelete: Cascade)
  liveSession       ForgeLiveSession?      @relation(fields: [liveSessionId], references: [id], onDelete: SetNull)
  playGroup         ForgePlayGroup?        @relation(fields: [playGroupId], references: [id], onDelete: SetNull)
  facilitator       User                   @relation("ForgeSharedGameFacilitator", fields: [facilitatorUserId], references: [id], onDelete: Cascade)

  @@index([activityId, status])
  @@index([courseId, status])
  @@index([playGroupId, status])
}

model ForgeGameSpec {
  id         String                  @id @default(cuid())
  companyId  String
  engine     String
  version    Int                     @default(1)
  title      String
  definition Json
  status     String                  @default("draft")
  createdAt  DateTime                @default(now())
  updatedAt  DateTime                @updatedAt
  company    Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  activities ForgeLearningActivity[]

  @@index([companyId, status])
}

model ForgeGameSession {
  id         String                @id @default(cuid())
  activityId String
  userId     String
  state      Json                  @default("{}")
  status     String                @default("in_progress")
  score      Float?
  insights   Json?
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt
  activity   ForgeLearningActivity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  user       User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([activityId, userId])
  @@index([userId, status])
}

model ForgeEnrollment {
  id           String      @id @default(cuid())
  courseId     String
  userId       String
  status       String      @default("active")
  /** course_only = só este curso, sem catálogo FORGE; organization = equipa da org */
  accessScope  String      @default("course_only")
  enrolledAt   DateTime    @default(now())
  completedAt  DateTime?
  invitedById      String?
  /** Token de convite (link mágico /hub/forge/entrar?token=) */
  inviteToken           String?   @unique
  inviteExpiresAt       DateTime?
  magicLoginToken       String?   @unique
  magicLoginExpiresAt   DateTime?
  passwordSetAt         DateTime?
  playGroupId           String?
  course    ForgeCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  playGroup ForgePlayGroup? @relation(fields: [playGroupId], references: [id], onDelete: SetNull)

  @@unique([courseId, userId])
  @@index([userId])
  @@index([inviteToken])
  @@index([magicLoginToken])
  @@index([playGroupId])
}

model ForgeActivityProgress {
  id          String                @id @default(cuid())
  activityId  String
  userId      String
  status      String                @default("not_started")
  score       Float?
  payload     Json?
  completedAt DateTime?
  updatedAt   DateTime              @updatedAt
  activity    ForgeLearningActivity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  user        User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([activityId, userId])
  @@index([userId, status])
}

model ForgeLearnerProfile {
  id        String      @id @default(cuid())
  courseId  String
  userId    String
  xp        Int         @default(0)
  level     Int         @default(1)
  badges    Json        @default("[]")
  updatedAt DateTime    @updatedAt
  course    ForgeCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([courseId, userId])
}

/// Mapa personal, materiais e histórico por aluno (conta individual)
model ForgeLearnerJourney {
  id         String      @id @default(cuid())
  courseId   String
  userId     String
  /** Estaciones/módulos + tablero personal */
  mapState   Json        @default("{}")
  /** Fichas, insights, entregas */
  materials  Json        @default("[]")
  /** Línea de tiempo de eventos */
  timeline   Json        @default("[]")
  updatedAt  DateTime    @updatedAt
  createdAt  DateTime    @default(now())
  course     ForgeCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([courseId, userId])
  @@index([courseId])
  @@index([userId])
}

model ForgeGamificationEvent {
  id        String   @id @default(cuid())
  companyId String
  userId    String
  courseId  String?
  type      String
  payload   Json?
  createdAt DateTime @default(now())
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([companyId, createdAt])
  @@index([userId, courseId])
}

model ForgeCertificate {
  id         String      @id @default(cuid())
  companyId  String
  courseId   String
  userId     String
  verifyCode String      @unique
  title      String
  issuedAt   DateTime    @default(now())
  metadata   Json?
  company    Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  course     ForgeCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([courseId, userId])
  @@index([companyId])
  @@index([verifyCode])
}

