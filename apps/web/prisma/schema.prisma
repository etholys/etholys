  itemsJson   String
  /// Percentagem de itens marcados como cumpridos (0-100)
  completionPct Int    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fund        Fund     @relation(fields: [fundId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId, fundId])
  @@index([companyId])
}

/// Rede de desenvolvimento Nexus: cooperativa + filiais, ou rede comercial informal, etc.
model NexusNetwork {
  id              String               @id @default(cuid())
  name            String
  /// COOP_HIERARCHY | SALES_NETWORK | MIXED
  kind            String               @default("COOP_HIERARCHY")
  anchorCompanyId String
  /// Projeto SIEP opcional que contextualiza toda a rede (ex.: projeto temporário)
  siepProjectId   String?
  isActive        Boolean              @default(true)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  anchorCompany   Company              @relation("NexusNetworkAnchor", fields: [anchorCompanyId], references: [id], onDelete: Cascade)
  siepProject     Project?             @relation("NexusNetworkSiepProject", fields: [siepProjectId], references: [id])
  members         NexusNetworkMember[]
  ventureState    NexusVentureState?

  @@index([anchorCompanyId])
  @@index([siepProjectId])
}

/// Jornada tipo incubadora + prontidão internacional (Nexus)
model NexusVentureState {
  id                       String         @id @default(cuid())
  companyId                String?        @unique
  networkId                String?        @unique
  /// DISCOVER | FOCUS | BUILD | MEASURE | SCALE_GLOBAL
  stage                    String         @default("DISCOVER")
  targetRegions            String?
  internationalChecklist   Json?
  incubatorNotes           String?
  createdAt                DateTime       @default(now())
  updatedAt                DateTime       @updatedAt
  company                  Company?       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  network                  NexusNetwork?  @relation(fields: [networkId], references: [id], onDelete: Cascade)
}

model NexusNetworkMember {
  id            String       @id @default(cuid())
  networkId     String
  companyId     String
  /// anchor = empresa mãe / âncora; member = filial ou participante da rede
  memberRole    String       @default("member")
  /// Override opcional: projeto SIEP específico deste membro (senão usa o da rede)
  siepProjectId String?
  sortOrder     Int          @default(0)
  createdAt     DateTime     @default(now())
  company       Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  network       NexusNetwork @relation(fields: [networkId], references: [id], onDelete: Cascade)
  siepProject   Project?     @relation("NexusMemberSiepProject", fields: [siepProjectId], references: [id])

  @@unique([networkId, companyId])
  @@index([companyId])
  @@index([networkId, memberRole])
}

