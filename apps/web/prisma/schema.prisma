model FundhubDiscoveryRun {
  id                String    @id @default(cuid())
  companyId         String
  initiatedByUserId String?
  source            String    @default("api")
  status            String    @default("running")
  maxUrls           Int?
  rematchRequested  Boolean   @default(false)
  notifyRequested   Boolean   @default(true)
  scanned           Int       @default(0)
  created           Int       @default(0)
  updated           Int       @default(0)
  errorCount        Int       @default(0)
  rematchUpdated    Int?
  errorsJson        String?
  startedAt         DateTime  @default(now())
  finishedAt        DateTime?
  durationMs        Int?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  company           Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  initiatedBy       User?     @relation(fields: [initiatedByUserId], references: [id])

  @@index([companyId, startedAt])
  @@index([companyId, status])
}

model FundhubAlert {
  id          String    @id @default(cuid())
  companyId   String
  userId      String
  name        String
  description String?
  /// Mínimo match % para ativar alerta (ex: 70)
  matchThreshold Int     @default(70)
  /// true = ativo, false = desativado
  isActive    Boolean   @default(true)
  /// Tipo de notificação: 'in_app' | 'email' | 'both'
  notificationType String @default("in_app")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  triggers    FundhubAlertTrigger[]

  @@unique([companyId, userId])
  @@index([companyId])
  @@index([isActive])
}

