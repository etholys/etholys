# Copie para apps/web/.env no servidor (valores de PRODUÇÃO)
# cp .env.production.example .env

# URL EXACTA que os alunos abrem no browser (HTTPS, sem barra no fim)
NEXTAUTH_URL=https://forge.etholys.com
NEXTAUTH_SECRET=GERE_COM_openssl_rand_base64_32

# O docker-compose.prod.yml injeta DATABASE_URL para o contentor web.
# Para scripts locais no servidor (seed), use o mesmo host postgres:5432 dentro da rede
# ou localhost se expuser porta (não recomendado).

# Convites e recuperação de senha (Resend — https://resend.com/domains)
# 1. Verifique etholys.com no Resend (registos DNS SPF + DKIM no Cloudflare)
# 2. Copie a API key e configure no servidor:
#    RESEND_API_KEY=re_xxx bash scripts/configure-email-production.sh
# RESEND_API_KEY=re_...
AUTH_EMAIL_FROM="Etholys <noreply@etholys.com>"
FORGE_EMAIL_FROM="Etholys <noreply@etholys.com>"

# Gemini (se usar outras funções da app)
# GEMINI_API_KEY=...
