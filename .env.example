# Copie para .env na raiz deste repositório (Etholys/) para Docker Compose substituir variáveis
# e para rodar Prisma / Python no host (fora do container).
# Postgres exposto no host: porta 5433. Dentro da rede Docker use host "postgres" e porta 5432.
DATABASE_URL="postgresql://etholys:etholys_dev_change_me@localhost:5433/etholys?schema=public"

# Next.js / Compose: usado na substituição ${NEXTAUTH_SECRET} no docker-compose (opcional).
NEXTAUTH_SECRET=dev-etholys-nextauth-mude-em-producao

# Next.js (Docker): o compose força DATABASE_URL para o Postgres local; NEXTAUTH_URL=http://localhost:3000

# API FastAPI no Docker já recebe DATABASE_URL pelo docker-compose (postgres:5432).
# Rodando uvicorn no host: use a URL acima (localhost:5433).

# --- IA (chat grava em ai_conversation / ai_message no Postgres) ---
# ollama = modelo na sua máquina (instale https://ollama.com e baixe um modelo)
# openai = API OpenAI ou compatível (Cursor não precisa disso para o chat da API)
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2

# Se AI_PROVIDER=openai:
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# Instruções de sistema enviadas ao modelo (opcional)
# AI_SYSTEM_PROMPT=You are a helpful assistant...
